@article{Sulimani2025,
   abstract = {Credit card fraud detection is a critical task in financial systems, requiring effective algorithms to accurately classify transactions as fraudulent or non-fraudulent. This paper proposes a novel approach, combining the AdaBoost algorithm with Long Short-Term Memory (LSTM) networks, called the AdaBoost-LSTM algorithm, to improve the detection of fraud in sequential transaction data. The AdaBoost algorithm is widely known for its ability to combine multiple weak classifiers into a strong one. In this work, we adapt it to sequential learning tasks by leveraging Long Short-Term Memory (LSTM) networks, which effectively capture temporal dependencies in transaction data. In this approach, multiple LSTM models are trained sequentially, with each model focusing on the misclassified samples from the previous one. Sample weights are adjusted at each iteration to emphasize hard-to-classify instances, and transfer learning is employed to initialize each new LSTM with the parameters learned from the previous iteration, thus reducing computational costs and overfitting risks. The proposed method is evaluated on a credit card fraud detection dataset, demonstrating its effectiveness in improving classification accuracy compared to traditional models.},
   author = {Hamza H. Sulimani},
   note = {doi:10.1109/ACCESS.2025.3642207},
   issn = {21693536},
   journal = {IEEE Access},
   keywords = {AdaBoost,Credit card fraud detection,long short-term memory (LSTM),sequential learning,transfer learning},
   pages = {212504-212516},
   publisher = {Institute of Electrical and Electronics Engineers Inc.},
   title = {AdaBoost-LSTM: A Hybrid Ensemble Framework for Sequential Credit Card Fraud Detection},
   volume = {13},
   year = {2025}
}
